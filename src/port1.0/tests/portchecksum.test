} -result {1 checksums-prepend 20}

test find_block_value_default_fallback {
    Distfile not in any block falls back correctly (value not in Portfile at all)
} -body {
    set lines [list \
        "checksums           rmd160  abc123def456 \\" \
        "                    sha256  ghi789jkl012" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    # A completely new checksum that doesn't appear in the Portfile
    portchecksum::find_block_for_value $lines $blocks "zzzNEWHASH999"
} -result -1

# ============================================================
# Integration test combining all three procs
# ============================================================

test integration_multi_block_portfile {
    Parse a multi-block Portfile, find values, format suggestions per block
} -body {
    set lines [list \
        "    checksums       git-2.53.0.tar.xz \\" \
        "                    rmd160  f125aaa111bbb222 \\" \
        "                    sha256  5818ccc333ddd444 \\" \
        "                    size    7993096 \\" \
        "                    git-manpages-2.53.0.tar.xz \\" \
        "                    rmd160  dbc6eee555fff666 \\" \
        "                    sha256  957fggg777hhh888 \\" \
        "                    size    614136" \
        "" \
        "        checksums-append    git-htmldocs-2.53.0.tar.xz \\" \
        "                            rmd160  1ffciii999jjj000 \\" \
        "                            sha256  994bkkk111lll222 \\" \
        "                            size    1675212" \
    ]

    set blocks [portchecksum::parse_checksum_block_formats $lines]

    # Find which block each value belongs to
    set b_git [portchecksum::find_block_for_value $lines $blocks "f125aaa111bbb222"]
    set b_man [portchecksum::find_block_for_value $lines $blocks "dbc6eee555fff666"]
    set b_html [portchecksum::find_block_for_value $lines $blocks "1ffciii999jjj000"]

    # Verify block assignments
    set blk0 [lindex $blocks 0]
    set blk1 [lindex $blocks 1]

    # Format a suggestion for the first block
    set sums0 [list "rmd160  new_rmd_git" "sha256  new_sha_git"]
    set fmt0 [portchecksum::format_checksum_suggestion \
        [dict get $blk0 keyword] [dict get $blk0 indent] \
        [dict get $blk0 keyword_width] $sums0]

    # Format a suggestion for the second block
    set sums1 [list "rmd160  new_rmd_html" "sha256  new_sha_html"]
    set fmt1 [portchecksum::format_checksum_suggestion \
        [dict get $blk1 keyword] [dict get $blk1 indent] \
        [dict get $blk1 keyword_width] $sums1]

    # Verify: git and manpages in block 0, htmldocs in block 1
    # Block 0: 4-space indent, keyword_width=20, starts at line 0 (1-based: 1)
    # Block 1: 8-space indent, checksums-append, keyword_width=28, starts at line 9 (1-based: 10)
    set starts_with_indent [string match "    checksums*" $fmt0]
    set starts_with_append [string match "        checksums-append*" $fmt1]
    set lineno0 [expr {[dict get $blk0 start_line] + 1}]
    set lineno1 [expr {[dict get $blk1 start_line] + 1}]
    list $b_git $b_man $b_html $starts_with_indent $starts_with_append $lineno0 $lineno1
} -result {0 0 1 1 1 1 10}

test integration_line_hint {
    Verify line hint uses 1-based line numbers from block start_line
} -body {
    set lines [list \
        "PortSystem 1.0" \
        "name foo" \
        "version 1.0" \
        "" \
        "checksums           rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    789" \
        "" \
        "    checksums-append    rmd160  ghi789 \\" \
        "                        sha256  jkl012" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set hints [list]
    foreach block $blocks {
        set lineno [expr {[dict get $block start_line] + 1}]
        lappend hints "[dict get $block keyword] on line $lineno"
    }
    join $hints ", "
} -result "checksums on line 5, checksums-append on line 9"

test integration_variable_distfile_names {
    Extract original variable expressions for distfile names (go pattern)
} -body {
    set lines [list \
        "        checksums   \${go_src_dist} \\" \
        "                    rmd160  f0b0aaa111 \\" \
        "                    sha256  b1ffbbb222 \\" \
        "                    size    30797581 \\" \
        "                    \${go_armbin_dist} \\" \
        "                    rmd160  2d1dccc333 \\" \
        "                    sha256  0db2ddd444 \\" \
        "                    size    76429684 \\" \
        "                    \${go_amdbin_dist} \\" \
        "                    rmd160  86fdeee555 \\" \
        "                    sha256  ecb3fff666 \\" \
        "                    size    80113551" \
    ]

    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set block [lindex $blocks 0]

    # Extract original distfile names
    set orig_names [portchecksum::extract_block_distfile_names $lines $block]

    # Simulate resolved distfile names and map by position
    set resolved_names [list "go1.26.0.src.tar.gz" "go1.26.0.darwin-arm64.tar.gz" "go1.26.0.darwin-amd64.tar.gz"]
    set original_map [dict create]
    for {set n 0} {$n < [llength $resolved_names] && $n < [llength $orig_names]} {incr n} {
        dict set original_map [lindex $resolved_names $n] [lindex $orig_names $n]
    }

    # Build sums using original names
    set sums [list]
    foreach rname $resolved_names {
        lappend sums [dict get $original_map $rname]
        lappend sums "rmd160  newhash1"
        lappend sums "sha256  newhash2"
        lappend sums "size    99999"
    }

    set result [portchecksum::format_checksum_suggestion \
        [dict get $block keyword] [dict get $block indent] \
        [dict get $block keyword_width] $sums]

    # Verify original expressions are in the output, not resolved names
    set has_go_src [expr {[string first {${go_src_dist}} $result] >= 0}]
    set has_go_arm [expr {[string first {${go_armbin_dist}} $result] >= 0}]
    set has_go_amd [expr {[string first {${go_amdbin_dist}} $result] >= 0}]
    set no_resolved [expr {[string first "go1.26.0" $result] < 0}]
    list $has_go_src $has_go_arm $has_go_amd $no_resolved
} -result {1 1 1 1}

cleanupTests
