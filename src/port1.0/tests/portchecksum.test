test verify_unknown_checksum_format {
    Test that we respond as expected to an unknown checksum format
} -body {
    set checksum "thisisnotread"
    if {[portchecksum::verify_checksum_format "lol22" $checksum] != -1} {
        return "FAIL: did not respond as expected to an unknown checksum"
    }
    return "Verify unknown successful"
} -result "Verify unknown successful"



# test checksum_start


test checksum_main {
    Checksum main unit test. Checks for empty files.
} -body {
    set all_dist_files {file file2}
    set checksum.skip yes

    if {[portchecksum::checksum_main] != 0} {
        return "FAIL: checksum not skipped"
    }

    set checksum.skip no
    set distpath $pwd/dpath

    file mkdir $distpath
    close [open $distpath/file w]
    close [open $distpath/file2 w]
    array set checksums_array {
        file {md5 d41d8cd98f00b204e9800998ecf8427e}
        file2 {sha1 da39a3ee5e6b4b0d3255bfef95601890afd80709}
    }

    if {[portchecksum::checksum_main] != 0} {
        return "FAIL: incorrect checksum"
    }
    return "Checksum main successful."

} -cleanup {
    file delete -force $distpath
    file delete -force file
    file delete -force file2
} -result "Checksum main successful."


# ============================================================
# Tests for portchecksum::parse_checksum_block_formats
# ============================================================

test parse_block_formats_standard {
    Parse a standard top-level checksums block (vim/gradle style, keyword_width=20)
} -body {
    set lines [list \
        "PortSystem 1.0" \
        "name foo" \
        "checksums           rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    789" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set b [lindex $blocks 0]
    list [llength $blocks] \
         [dict get $b keyword] \
         [dict get $b indent] \
         [dict get $b keyword_width] \
         [dict get $b type_width] \
         [dict get $b start_line] \
         [dict get $b end_line]
} -result {1 checksums {} 20 8 2 4}

test parse_block_formats_wide {
    Parse a wide-format checksums block (curl style, keyword_width=32)
} -body {
    set lines [list \
        "checksums                       rmd160  abc123 \\" \
        "                                sha256  def456 \\" \
        "                                size    789" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set b [lindex $blocks 0]
    list [dict get $b keyword_width] [dict get $b start_line] [dict get $b end_line]
} -result {32 0 2}

test parse_block_formats_indented {
    Parse an indented checksums block (git subport style, 4-space indent)
} -body {
    set lines [list \
        "subport git-devel \{" \
        "    checksums       rmd160  abc123 \\" \
        "                    sha256  def456" \
        "\}" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set b [lindex $blocks 0]
    list [dict get $b indent] [dict get $b keyword_width] [dict get $b start_line] [dict get $b end_line]
} -result {{    } 20 1 2}

test parse_block_formats_two_blocks {
    Parse two blocks: checksums + checksums-append with different indentation
} -body {
    set lines [list \
        "checksums           rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    789" \
        "" \
        "        checksums-append    rmd160  ghi789 \\" \
        "                            sha256  jkl012 \\" \
        "                            size    321" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set b0 [lindex $blocks 0]
    set b1 [lindex $blocks 1]
    list [llength $blocks] \
         [dict get $b0 keyword] [dict get $b0 indent] [dict get $b0 keyword_width] \
         [dict get $b1 keyword] [dict get $b1 indent] [dict get $b1 keyword_width]
} -result {2 checksums {} 20 checksums-append {        } 28}

test parse_block_formats_none {
    Return empty list when no checksums line exists
} -body {
    set lines [list "PortSystem 1.0" "name foo" "version 1.0"]
    portchecksum::parse_checksum_block_formats $lines
} -result {}

test parse_block_formats_single_line {
    Parse a single-line checksums (no continuation)
} -body {
    set lines [list \
        "checksums   rmd160 abc123 sha256 def456 size 789" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set b [lindex $blocks 0]
    list [llength $blocks] [dict get $b start_line] [dict get $b end_line] [dict get $b keyword_width]
} -result {1 0 0 12}

test parse_block_formats_llvm_style {
    Parse wide-format checksums (llvm style, keyword_width=24)
} -body {
    set lines [list \
        "checksums               rmd160  abc123 \\" \
        "                        sha256  def456 \\" \
        "                        size    789" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set b [lindex $blocks 0]
    dict get $b keyword_width
} -result 24

# ============================================================
# Tests for portchecksum::find_block_for_value
# ============================================================

test find_block_value_first {
    Find value in the first block
} -body {
    set lines [list \
        "checksums           rmd160  abc123def456 \\" \
        "                    sha256  ghi789jkl012 \\" \
        "                    size    12345" \
        "" \
        "checksums-append    rmd160  mno345pqr678 \\" \
        "                    sha256  stu901vwx234" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::find_block_for_value $lines $blocks "abc123def456"
} -result 0

test find_block_value_second {
    Find value in the second block (checksums-append)
} -body {
    set lines [list \
        "checksums           rmd160  abc123def456 \\" \
        "                    sha256  ghi789jkl012 \\" \
        "                    size    12345" \
        "" \
        "checksums-append    rmd160  mno345pqr678 \\" \
        "                    sha256  stu901vwx234" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::find_block_for_value $lines $blocks "mno345pqr678"
} -result 1

test find_block_value_not_found {
    Return -1 when value not found in any block
} -body {
    set lines [list \
        "checksums           rmd160  abc123def456" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::find_block_for_value $lines $blocks "zzz999nonexistent"
} -result -1

test find_block_value_outside_blocks {
    Return -1 when value found on a line outside any block range
} -body {
    set lines [list \
        "checksums           rmd160  abc123def456" \
        "" \
        "# some comment mentioning xyz789mno456" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::find_block_for_value $lines $blocks "xyz789mno456"
} -result -1

# ============================================================
# Tests for portchecksum::extract_block_distfile_names
# ============================================================

test extract_distfiles_variable_names {
    Extract distfile names with Tcl variable expressions (go pattern)
} -body {
    set lines [list \
        "        checksums   \${go_src_dist} \\" \
        "                    rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    12345 \\" \
        "                    \${go_armbin_dist} \\" \
        "                    rmd160  ghi789 \\" \
        "                    sha256  jkl012 \\" \
        "                    size    67890" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::extract_block_distfile_names $lines [lindex $blocks 0]
} -result [list {${go_src_dist}} {${go_armbin_dist}}]

test extract_distfiles_literal_names {
    Extract literal distfile names (git pattern)
} -body {
    set lines [list \
        "    checksums       git-2.53.0.tar.xz \\" \
        "                    rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    7993096 \\" \
        "                    git-manpages-2.53.0.tar.xz \\" \
        "                    rmd160  ghi789 \\" \
        "                    sha256  jkl012 \\" \
        "                    size    614136" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::extract_block_distfile_names $lines [lindex $blocks 0]
} -result {git-2.53.0.tar.xz git-manpages-2.53.0.tar.xz}

test extract_distfiles_single_implicit {
    Return empty list when single distfile has no name in block
} -body {
    set lines [list \
        "checksums           rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    789" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::extract_block_distfile_names $lines [lindex $blocks 0]
} -result {}

test extract_distfiles_mixed_expressions {
    Extract names with mixed variable and literal expressions
} -body {
    set lines [list \
        "checksums           \${distname}\${extract.suffix} \\" \
        "                    rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    11111 \\" \
        "                    \${name}-docs-\${version}.tar.gz \\" \
        "                    rmd160  ghi789 \\" \
        "                    sha256  jkl012 \\" \
        "                    size    22222" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    portchecksum::extract_block_distfile_names $lines [lindex $blocks 0]
} -result [list {${distname}${extract.suffix}} {${name}-docs-${version}.tar.gz}]

# ============================================================
# Tests for portchecksum::format_checksum_suggestion
# ============================================================

test format_suggestion_standard {
    Standard 20-width format matches historical output
} -body {
    set sums [list "rmd160  abc123" "sha256  def456" "size    789"]
    portchecksum::format_checksum_suggestion "checksums" "" 20 $sums
} -result "checksums           rmd160  abc123 \\\n                    sha256  def456 \\\n                    size    789"

test format_suggestion_indented {
    With 4-space indent prefix
} -body {
    set sums [list "rmd160  abc123" "sha256  def456"]
    portchecksum::format_checksum_suggestion "checksums" "    " 20 $sums
} -result "    checksums       rmd160  abc123 \\\n                    sha256  def456"

test format_suggestion_wide {
    With wider keyword_width (32, curl style)
} -body {
    set sums [list "rmd160  abc123" "sha256  def456"]
    portchecksum::format_checksum_suggestion "checksums" "" 32 $sums
} -result "checksums                       rmd160  abc123 \\\n                                sha256  def456"

test format_suggestion_append_keyword {
    With checksums-append keyword and 8-space indent
} -body {
    set sums [list "rmd160  abc123" "sha256  def456"]
    portchecksum::format_checksum_suggestion "checksums-append" "        " 28 $sums
} -result "        checksums-append    rmd160  abc123 \\\n                            sha256  def456"

test format_suggestion_multi_distfile {
    Multiple distfiles with names in sums list
} -body {
    set sums [list "file1.tar.gz" "rmd160  abc123" "sha256  def456" "file2.tar.gz" "rmd160  ghi789" "sha256  jkl012"]
    portchecksum::format_checksum_suggestion "checksums" "" 20 $sums
} -result "checksums           file1.tar.gz \\\n                    rmd160  abc123 \\\n                    sha256  def456 \\\n                    file2.tar.gz \\\n                    rmd160  ghi789 \\\n                    sha256  jkl012"

test format_suggestion_single_entry {
    Single checksum entry (no continuation needed)
} -body {
    set sums [list "sha256  abc123"]
    portchecksum::format_checksum_suggestion "checksums" "" 20 $sums
} -result "checksums           sha256  abc123"

test parse_block_formats_prepend {
    Parse a checksums-prepend block (curl style)
} -body {
    set lines [list \
        "checksums-prepend   rmd160  abc123 \\" \
        "                    sha256  def456 \\" \
        "                    size    789" \
    ]
    set blocks [portchecksum::parse_checksum_block_formats $lines]
    set b [lindex $blocks 0]
