# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

package require tcltest 2
namespace import tcltest::*

set pwd [file dirname [file normalize $argv0]]

source ../port_test_autoconf.tcl
package require macports 1.0

array set ui_options {}
#set ui_options(ports_debug)   yes
#set ui_options(ports_verbose) yes
mportinit ui_options

source ./library.tcl
macports_worker_init

set dir [file normalize [file join $pwd ..]]
source [file join $dir pkgIndex.tcl]
unset dir

package require portprovenance 1.0
package require portchecksum 1.0
package require portbump 1.0

proc write_portbump_file {path contents} {
    set fd [open $path w]
    puts -nonewline $fd $contents
    close $fd
}

proc read_portbump_file {path} {
    set fd [open $path r]
    set contents [read $fd]
    close $fd
    return $contents
}

proc append_portbump_option_provenance {option action path line cmd {portname {}} {scope {}} {scope_name {}}} {
    set record [dict create \
        option $option \
        action $action \
        file [file normalize $path] \
        line $line \
        cmd $cmd]

    switch -- $option {
        checksums {
            if {![catch {lassign [portbump::evaluate_checksum_command $cmd] _ args}]} {
                dict set record args $args
            }
        }
        revision {
            if {[regexp {revision[[:space:]\\]+([0-9]+)} $cmd -> revision]} {
                dict set record args [list $revision]
            }
        }
    }

    if {$portname ne {}} {
        dict set record portname $portname
    }
    if {$scope ne {}} {
        dict set record scope $scope
    }
    if {$scope_name ne {}} {
        dict set record scope_name $scope_name
    }

    lappend ::portprovenance::option_provenance $record
}

proc reset_portbump_test_state {} {
    foreach var {
        all_dist_files
        checksums
        distpath
        htmlfile_path
        name
        portpath
        ports_bump_patch
        revision
        subport
        version
        wrong_mimetype
    } {
        unset -nocomplain ::$var
    }
    catch {array unset ::checksums_array}
    unset -nocomplain ::PortInfo(name)
    unset -nocomplain ::PortInfo(subports)
    unset -nocomplain ::PortInfo(variants)
    unset -nocomplain ::PortInfo(vinfo)
    unset -nocomplain ::portutil::all_variants
    unset -nocomplain ::portutil::autoconf::diff_path
    unset -nocomplain ::portutil::autoconf::file_path
    portprovenance::reset_option_provenance
    portprovenance::reset_scope
}


test bump_main_updates_all_distfiles {
    Bump main updates every distfile checksum instead of only the last one.
} -body {
    reset_portbump_test_state

    set tmpdir [file join $pwd bump-main-updates-all-distfiles]
    set portpath [file join $tmpdir port]
    set distpath [file join $tmpdir distfiles]
    set first_distfile first.tar.gz
    set second_distfile second.tar.gz

    file mkdir $portpath
    file mkdir $distpath

    write_portbump_file [file join $distpath $first_distfile] alpha
    write_portbump_file [file join $distpath $second_distfile] bravo

    set first_md5 [portchecksum::calc_md5 [file join $distpath $first_distfile]]
    set second_md5 [portchecksum::calc_md5 [file join $distpath $second_distfile]]
    set shared_size [file size [file join $distpath $first_distfile]]

    set first_old_md5 11111111111111111111111111111111
    set second_old_md5 22222222222222222222222222222222

    set all_dist_files [list $first_distfile $second_distfile]
    set checksums [list \
        $first_distfile md5 $first_old_md5 size $shared_size \
        $second_distfile md5 $second_old_md5 size $shared_size]
    set ports_bump_patch no
    set subport bump-test
    set version 1.2.3
    set revision 7

    write_portbump_file [file join $portpath Portfile] [format {revision        7
checksums       %s \
                    md5     %s \
                    size    %s \
                %s \
                    md5     %s \
                    size    %s
} $first_distfile $first_old_md5 $shared_size $second_distfile $second_old_md5 $shared_size]

    if {[catch {portbump::bump_main} result]} {
        return "FAIL: $result"
    }

    set updated_portfile [read_portbump_file [file join $portpath Portfile]]

    if {![string match "*$first_md5*" $updated_portfile]} {
        return "FAIL: first distfile checksum not updated"
    }
    if {![string match "*$second_md5*" $updated_portfile]} {
        return "FAIL: second distfile checksum not updated"
    }
    if {[string match "*$first_old_md5*" $updated_portfile]} {
        return "FAIL: stale checksum for first distfile still present"
    }
    if {[string match "*$second_old_md5*" $updated_portfile]} {
        return "FAIL: stale checksum for second distfile still present"
    }
    if {![regexp {revision[[:space:]]+0} $updated_portfile]} {
        return "FAIL: revision not reset"
    }

    return "Bump main updated all distfiles."
} -cleanup {
    reset_portbump_test_state
    file delete -force [file join $pwd bump-main-updates-all-distfiles]
} -result "Bump main updated all distfiles."


test bump_main_updates_only_the_matching_size {
    Bump main updates the right size field when multiple distfiles share an old size.
} -body {
    reset_portbump_test_state

    set tmpdir [file join $pwd bump-main-updates-only-the-matching-size]
    set portpath [file join $tmpdir port]
    set distpath [file join $tmpdir distfiles]
    set first_distfile first.tar.gz
    set second_distfile second.tar.gz

    file mkdir $portpath
    file mkdir $distpath

    write_portbump_file [file join $distpath $first_distfile] alpha
    write_portbump_file [file join $distpath $second_distfile] bravo!

    set first_md5 [portchecksum::calc_md5 [file join $distpath $first_distfile]]
    set second_md5 [portchecksum::calc_md5 [file join $distpath $second_distfile]]
    set first_size [file size [file join $distpath $first_distfile]]
    set second_size [file size [file join $distpath $second_distfile]]

    set all_dist_files [list $first_distfile $second_distfile]
    set checksums [list \
        $first_distfile md5 $first_md5 size $first_size \
        $second_distfile md5 $second_md5 size $first_size]
    set ports_bump_patch no
    set subport bump-test
    set version 1.2.3
    set revision 3

    write_portbump_file [file join $portpath Portfile] [format {revision        3
checksums       %s \
                    md5     %s \
                    size    %s \
                %s \
                    md5     %s \
                    size    %s
} $first_distfile $first_md5 $first_size $second_distfile $second_md5 $first_size]

    if {[catch {portbump::bump_main} result]} {
        return "FAIL: $result"
    }

    set updated_portfile [read_portbump_file [file join $portpath Portfile]]

    if {[llength [regexp -all -inline [format {size[[:space:]]+%s} $second_size] $updated_portfile]] != 1} {
        return "FAIL: incorrect number of updated size entries"
    }
    if {![regexp [format {size[[:space:]]+%s[[:space:]\\]+%s[[:space:]\\]+md5[[:space:]]+%s[[:space:]\\]+size[[:space:]]+%s} \
            $first_size $second_distfile $second_md5 $second_size] $updated_portfile]} {
        return "FAIL: second distfile size not updated"
    }
    if {![regexp [format {checksums[[:space:]\\]+%s[[:space:]\\]+md5[[:space:]]+%s[[:space:]\\]+size[[:space:]]+%s} \
            $first_distfile $first_md5 $first_size] $updated_portfile]} {
        return "FAIL: first distfile size changed"
    }

    return "Bump main updated only the matching size."
} -cleanup {
    reset_portbump_test_state
    file delete -force [file join $pwd bump-main-updates-only-the-matching-size]
} -result "Bump main updated only the matching size."


test bump_main_updates_variable_distfile_tokens {
    Bump main rewrites checksums when the Portfile uses variable-expanded distfile names.
} -body {
    reset_portbump_test_state

    set tmpdir [file join $pwd bump-main-updates-variable-distfile-tokens]
    set portpath [file join $tmpdir port]
    set distpath [file join $tmpdir distfiles]
    set name pkg
    set first_distfile ${name}-x86_64-apple-darwin.zip
    set second_distfile ${name}-aarch64-apple-darwin.zip

    file mkdir $portpath
    file mkdir $distpath

    write_portbump_file [file join $distpath $first_distfile] x86-binary
    write_portbump_file [file join $distpath $second_distfile] arm-binary

    set first_rmd160 [portchecksum::calc_rmd160 [file join $distpath $first_distfile]]
    set first_sha256 [portchecksum::calc_sha256 [file join $distpath $first_distfile]]
    set first_size [file size [file join $distpath $first_distfile]]
    set second_rmd160 [portchecksum::calc_rmd160 [file join $distpath $second_distfile]]
    set second_sha256 [portchecksum::calc_sha256 [file join $distpath $second_distfile]]
    set second_size [file size [file join $distpath $second_distfile]]

    set all_dist_files [list $first_distfile $second_distfile]
    set checksums [list \
        $first_distfile rmd160 1111111111111111111111111111111111111111 sha256 2222222222222222222222222222222222222222222222222222222222222222 size 1 \
        $second_distfile rmd160 3333333333333333333333333333333333333333 sha256 4444444444444444444444444444444444444444444444444444444444444444 size 2]
    set ports_bump_patch no
    set subport bump-test
    set version 1.2.3
    set revision 0

    write_portbump_file [file join $portpath Portfile] {checksums           ${name}-x86_64-apple-darwin.zip \
                    rmd160  1111111111111111111111111111111111111111 \
                    sha256  2222222222222222222222222222222222222222222222222222222222222222 \
                    size    1 \
                    ${name}-aarch64-apple-darwin.zip \
                    rmd160  3333333333333333333333333333333333333333 \
                    sha256  4444444444444444444444444444444444444444444444444444444444444444 \
                    size    2
}

    if {[catch {portbump::bump_main} result]} {
        return "FAIL: $result"
    }

    set updated_portfile [read_portbump_file [file join $portpath Portfile]]

    foreach sum [list $first_rmd160 $first_sha256 $first_size $second_rmd160 $second_sha256 $second_size] {
        if {![string match "*$sum*" $updated_portfile]} {
            return "FAIL: updated checksum missing from Portfile"
        }
    }
    if {[string match *1111111111111111111111111111111111111111* $updated_portfile] ||
        [string match *2222222222222222222222222222222222222222222222222222222222222222* $updated_portfile] ||
        [string match *3333333333333333333333333333333333333333* $updated_portfile] ||
        [string match *4444444444444444444444444444444444444444444444444444444444444444* $updated_portfile]} {
        return "FAIL: stale checksum still present"
    }

    return "Bump main updated variable distfile tokens."
} -cleanup {
    reset_portbump_test_state
    file delete -force [file join $pwd bump-main-updates-variable-distfile-tokens]
} -result "Bump main updated variable distfile tokens."


test bump_main_updates_selected_distfile_from_multi_distfile_block {
    Bump main updates the selected distfile even when earlier checksum blocks remain untouched.
} -body {
    reset_portbump_test_state

    set tmpdir [file join $pwd bump-main-updates-selected-distfile]
    set portpath [file join $tmpdir port]
    set distpath [file join $tmpdir distfiles]
    set name pkg
    set first_distfile ${name}-x86_64-apple-darwin.zip
    set second_distfile ${name}-aarch64-apple-darwin.zip

    file mkdir $portpath
    file mkdir $distpath

    write_portbump_file [file join $distpath $second_distfile] arm-binary

    set second_rmd160 [portchecksum::calc_rmd160 [file join $distpath $second_distfile]]
    set second_sha256 [portchecksum::calc_sha256 [file join $distpath $second_distfile]]
    set second_size [file size [file join $distpath $second_distfile]]

    set all_dist_files [list $second_distfile]
    set checksums [list \
        $first_distfile rmd160 1111111111111111111111111111111111111111 sha256 2222222222222222222222222222222222222222222222222222222222222222 size 1 \
        $second_distfile rmd160 3333333333333333333333333333333333333333 sha256 4444444444444444444444444444444444444444444444444444444444444444 size 2]
    set ports_bump_patch no
    set subport bump-test
    set version 1.2.3
    set revision 0

    write_portbump_file [file join $portpath Portfile] {checksums           ${name}-x86_64-apple-darwin.zip \
                    rmd160  1111111111111111111111111111111111111111 \
                    sha256  2222222222222222222222222222222222222222222222222222222222222222 \
                    size    1 \
                    ${name}-aarch64-apple-darwin.zip \
                    rmd160  3333333333333333333333333333333333333333 \
                    sha256  4444444444444444444444444444444444444444444444444444444444444444 \
                    size    2
}

    if {[catch {portbump::bump_main} result]} {
        return "FAIL: $result"
    }

    set updated_portfile [read_portbump_file [file join $portpath Portfile]]

    foreach sum [list $second_rmd160 $second_sha256 $second_size] {
        if {![string match "*$sum*" $updated_portfile]} {
            return "FAIL: selected distfile checksum missing from Portfile"
        }
    }
    if {![string match {*1111111111111111111111111111111111111111*} $updated_portfile] ||
        ![string match {*2222222222222222222222222222222222222222222222222222222222222222*} $updated_portfile] ||
        ![string match {*size    1*} $updated_portfile]} {
        return "FAIL: untouched checksum block changed"
    }
    if {[string match {*3333333333333333333333333333333333333333*} $updated_portfile] ||
        [string match {*4444444444444444444444444444444444444444444444444444444444444444*} $updated_portfile]} {
        return "FAIL: stale checksum for selected distfile still present"
    }

    return "Bump main updated the selected distfile checksum block."
} -cleanup {
    reset_portbump_test_state
    file delete -force [file join $pwd bump-main-updates-selected-distfile]
} -result "Bump main updated the selected distfile checksum block."


test bump_main_updates_implicit_single_distfile_checksums {
    Bump main rewrites single-distfile checksum blocks that omit the distfile name.
} -body {
    reset_portbump_test_state

    set tmpdir [file join $pwd bump-main-updates-implicit-single-distfile]
    set portpath [file join $tmpdir port]
    set distpath [file join $tmpdir distfiles]
    set distfile archive.tar.gz

    file mkdir $portpath
    file mkdir $distpath

    write_portbump_file [file join $distpath $distfile] single-distfile

    set rmd160 [portchecksum::calc_rmd160 [file join $distpath $distfile]]
    set sha256 [portchecksum::calc_sha256 [file join $distpath $distfile]]
    set size [file size [file join $distpath $distfile]]

    set all_dist_files [list $distfile]
    set checksums [list rmd160 1111111111111111111111111111111111111111 sha256 2222222222222222222222222222222222222222222222222222222222222222 size 1]
    set ports_bump_patch no
    set subport bump-test
    set version 1.2.3
    set revision 9

    write_portbump_file [file join $portpath Portfile] {revision        9
checksums       rmd160  1111111111111111111111111111111111111111 \
                sha256  2222222222222222222222222222222222222222222222222222222222222222 \
                size    1
}

    if {[catch {portbump::bump_main} result]} {
        return "FAIL: $result"
    }

    set updated_portfile [read_portbump_file [file join $portpath Portfile]]

    foreach sum [list $rmd160 $sha256 $size] {
