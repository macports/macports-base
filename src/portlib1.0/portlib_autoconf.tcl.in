package provide portlib 1.0
namespace eval portlib::autoconf {
    variable aa_path "@AA@"
	variable bzip2_path "@BZIP2_BIN@"
    variable gzip_path "@GZIP_BIN@"
    variable lzma_path "@LZMA@"
	variable pax_path "@PAX@"
	variable tar_path "@TAR@"
	variable unzip_path "@UNZIP@"
	variable xar_path "@XAR@"
	variable xz_path "@XZ@"
	variable zip_path "@ZIP@"
}
