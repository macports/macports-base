# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

package require tcltest 2
namespace import tcltest::*

set pwd [file dirname [file normalize $argv0]]

set macports_dir $pwd/../../macports1.0
source ${macports_dir}/macports_test_autoconf.tcl
source ${macports_dir}/tests/test_setup.tcl

package require portlib

test get_archive_sites_conf_values {
    Get archive sites conf values unit test.
} -setup {
    file mkdir $pwd/archive_sites
    set fd [open $pwd/archive_sites/archive_sites.conf w+]
    puts $fd "name fondu"
    puts $fd "urls macports.org"
    puts $fd "type tgz"
    close $fd

    set macports::archive_sites_conf $pwd/archive_sites/archive_sites.conf
} -body {
    set res [portlib::archive_sites::get_archive_sites_conf_values]
    puts $res
    if {![dict exists $res sites fondu]} {
        return "FAIL: name not set"
    }
    if {[dict get $res sites fondu] ne "macports.org:nosubdir"} {
        return "FAIL: wrong sites set"
    }
    if {![dict exists $res archive_type fondu]} {
        return "FAIL: type not set"
    }
    if {[dict get $res archive_type fondu] ne "tgz"} {
        return "FAIL: wrong type set"
    }

    return "Get archive sites conf values successful."

} -cleanup {
    file delete -force $pwd/archive_sites
} -result "Get archive sites conf values successful."


test supportedArchiveTypes {
    Supported archive types unit test.
    Only tests xar, zip, cpio.
} -body {
    set archives [portlib::util::supportedArchiveTypes]

    foreach archive $archives {
        if {$archive == "xar" && ![file exists ${::portlib::autoconf::xar_path}]} {
            return "FAIL: xar detected but inexistent"
        }
        if {$archive == "zip" && ![file exists ${::portlib::autoconf::zip_path}]} {
            return "FAIL: zip detected but inexistent"
        }
        if {$archive == "cpio" && ![file exists ${::portlib::autoconf::pax_path}]} {
            return "FAIL: cpio detected but inexistent"
        }
    }
    return "Supported archives successful."
} -result "Supported archives successful."


cleanupTests
